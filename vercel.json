{
  "version": 2,
  "builds": [
    {
      "src": "api/td.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/macro.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/news.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/ai-analysis.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/td",
      "dest": "/api/td.js"
    },
    {
      "src": "/api/macro",
      "dest": "/api/macro.js"
    },
    {
      "src": "/api/news",
      "dest": "/api/news.js"
    },
    {
      "src": "/api/ai-analysis",
      "dest": "/api/ai-analysis.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
